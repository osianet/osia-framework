[Unit]
Description=Trigger OSIA RSS Ingress
After=network.target osia-orchestrator.service

[Service]
Type=oneshot
User=ubuntu
WorkingDirectory=/home/ubuntu/osia-framework
ExecStart=/home/ubuntu/osia-framework/.venv/bin/python -m src.gateways.rss_ingress
EnvironmentFile=/home/ubuntu/osia-framework/.env

[Install]
WantedBy=multi-user.target
