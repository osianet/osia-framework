[Unit]
Description=OSIA Persona Daemon (Persona 1)
After=network.target docker.service
Requires=docker.service

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/osia-framework
ExecStart=/home/ubuntu/osia-framework/.venv/bin/python -m src.agents.persona_daemon --persona 1
Restart=always
RestartSec=30
EnvironmentFile=/home/ubuntu/osia-framework/.env
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
