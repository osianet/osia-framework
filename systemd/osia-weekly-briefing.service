[Unit]
Description=Generate OSIA Weekly Department Briefings
After=network.target osia-orchestrator.service

[Service]
Type=oneshot
User=ubuntu
WorkingDirectory=/home/ubuntu/osia-framework
ExecStart=/home/ubuntu/osia-framework/.venv/bin/python -m src.cron.weekly_briefing
EnvironmentFile=/home/ubuntu/osia-framework/.env
# Weekly briefings can take a while — 8 desks × ~5 min each
TimeoutStartSec=3600

[Install]
WantedBy=multi-user.target
