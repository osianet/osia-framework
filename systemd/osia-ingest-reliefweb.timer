[Unit]
Description=Timer for OSIA ReliefWeb Disaster Events Ingestion — runs daily
Requires=osia-ingest-reliefweb.service

[Timer]
# Daily at 04:00 UTC — live API, picks up new events each day
OnCalendar=*-*-* 04:00:00
AccuracySec=10min
RandomizedDelaySec=1h
Persistent=true

[Install]
WantedBy=timers.target
