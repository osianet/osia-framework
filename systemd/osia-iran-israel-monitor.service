[Unit]
Description=Trigger OSIA Iran-Israel War Monitor
After=network.target osia-orchestrator.service

[Service]
Type=oneshot
User=ubuntu
WorkingDirectory=/home/ubuntu/osia-framework
ExecStart=/home/ubuntu/osia-framework/.venv/bin/python -m src.cron.iran_israel_monitor
EnvironmentFile=/home/ubuntu/osia-framework/.env

[Install]
WantedBy=multi-user.target
