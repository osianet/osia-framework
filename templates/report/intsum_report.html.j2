<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>OSIA INTSUM — {{ ref_number }}</title>
<style>
/* ================================================================
   OSIA INTELLIGENCE SUMMARY — DOCUMENT STYLESHEET
   Aesthetic: Traditional Intelligence Agency + Cyber Operations
   Palette: void_black / signal_green / amber_alert / liberation_red
   Typography: OsiaTitle (headings) · OsiaMono (body/code) · OsiaBody (meta)
   ================================================================ */

/* ── Ubuntu font family ──────────────────────────────────────── */
@font-face {
    font-family: 'OsiaTitle';
    src: url('/usr/share/fonts/truetype/ubuntu/Ubuntu-B.ttf') format('truetype');
    font-weight: bold;
    font-style: normal;
}
@font-face {
    font-family: 'OsiaMono';
    src: url('/usr/share/fonts/truetype/ubuntu/UbuntuMono-B.ttf') format('truetype');
    font-weight: bold;
    font-style: normal;
}
@font-face {
    font-family: 'OsiaMono';
    src: url('/usr/share/fonts/truetype/ubuntu/UbuntuMono-R.ttf') format('truetype');
    font-weight: normal;
    font-style: normal;
}
@font-face {
    font-family: 'OsiaBody';
    src: url('/usr/share/fonts/truetype/ubuntu/UbuntuSans[wdth,wght].ttf') format('truetype');
    font-weight: 100 900;
    font-style: normal;
}

@page {
    size: A4;
    margin: 0;

    @top-center {
        content: "";
    }
    @bottom-center {
        font-family: 'OsiaMono', 'Courier New', Courier, monospace;
        font-size: 7pt;
        color: #8B1A1A;
        content: "⬛ OSIA INTERNAL USE ONLY ⬛  |  " attr(data-ref) "  |  PAGE " counter(page) " OF " counter(pages);
        border-top: 1pt solid #3a0000;
        padding-top: 4pt;
        letter-spacing: 0.05em;
    }
}

* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

html, body {
    background-color: #0A0C0B;
    color: #D4CFC4;
    font-family: 'OsiaMono', 'Courier New', Courier, monospace;
    font-size: 9.5pt;
    line-height: 1.55;
}

/* ── Classification Banner ─────────────────────────────────────── */
.classification-banner {
    background-color: #5A0C0C;
    color: #ffffff;
    text-align: center;
    padding: 5pt 0;
    font-family: 'OsiaMono', 'Courier New', Courier, monospace;
    font-size: 8pt;
    font-weight: bold;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    border-bottom: 2pt solid #8B1A1A;
    page-break-after: avoid;
}

/* ── Document Header ───────────────────────────────────────────── */
.doc-header {
    background: linear-gradient(180deg, #0e140e 0%, #0A0C0B 100%);
    border-bottom: 1pt solid #1e4a1e;
    padding: 14pt 22pt 10pt 22pt;
    page-break-after: avoid;
}

.header-inner {
    display: flex;
    align-items: center;
    gap: 16pt;
}

.logo-cell {
    flex-shrink: 0;
}

.logo-cell img {
    height: 52pt;
    width: auto;
    opacity: 0.92;
}

.logo-placeholder {
    height: 52pt;
    width: 52pt;
    border: 1.5pt solid #2a5a2a;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 7pt;
    color: #2a5a2a;
    letter-spacing: 0.1em;
}

.agency-identity {
    flex: 1;
}

.agency-name {
    font-family: 'OsiaTitle', 'Ubuntu', sans-serif;
    font-size: 15pt;
    font-weight: bold;
    color: #00dd55;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    line-height: 1.1;
}

.agency-subtitle {
    font-family: 'OsiaBody', 'Ubuntu Sans', sans-serif;
    font-size: 7.5pt;
    font-weight: 300;
    color: #4A5248;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    margin-top: 2pt;
}

.doc-type {
    font-family: 'OsiaMono', 'Courier New', Courier, monospace;
    font-size: 11pt;
    font-weight: bold;
    color: #C8860A;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-top: 5pt;
}

.header-meta {
    text-align: right;
    flex-shrink: 0;
    min-width: 120pt;
}

.ref-number {
    font-family: 'OsiaMono', 'Courier New', Courier, monospace;
    font-size: 8pt;
    color: #C8860A;
    letter-spacing: 0.08em;
    font-weight: bold;
}

.header-timestamp {
    font-family: 'OsiaBody', 'Ubuntu Sans', sans-serif;
    font-size: 7.5pt;
    color: #4A5248;
    margin-top: 3pt;
}

/* ── Metadata Bar ──────────────────────────────────────────────── */
.metadata-bar {
    background-color: #0c150c;
    border-top: 1pt solid #1a3a1a;
    border-bottom: 2pt solid #1a3a1a;
    padding: 6pt 22pt;
    display: flex;
    flex-wrap: wrap;
    gap: 6pt 20pt;
    page-break-after: avoid;
}

.meta-item {
    font-family: 'OsiaBody', 'Ubuntu Sans', sans-serif;
    font-size: 7.5pt;
    color: #4A5248;
    letter-spacing: 0.05em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 200pt;
}

.meta-item.meta-source {
    max-width: 260pt;
}

.meta-item strong {
    font-family: 'OsiaMono', 'Courier New', Courier, monospace;
    color: #C8860A;
    letter-spacing: 0.08em;
}

/* ── Page body ─────────────────────────────────────────────────── */
.page-body {
    padding: 16pt 22pt 20pt 26pt;
    border-left: 3pt solid rgba(200, 134, 10, 0.18);
    background-image: repeating-linear-gradient(
        0deg,
        transparent,
        transparent 2px,
        rgba(0, 20, 0, 0.025) 2px,
        rgba(0, 20, 0, 0.025) 3px
    );
}

/* ── Body Content Typography ───────────────────────────────────── */
h1 {
    font-family: 'OsiaTitle', 'Ubuntu', sans-serif;
    font-size: 13pt;
    font-weight: bold;
    color: #C8860A;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin: 18pt 0 6pt 0;
    padding-bottom: 4pt;
    border-bottom: 1pt solid #3a2000;
    page-break-after: avoid;
}

h2 {
    font-family: 'OsiaTitle', 'Ubuntu', sans-serif;
    font-size: 11pt;
    font-weight: bold;
    color: #C8860A;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin: 14pt 0 5pt 0;
    padding-left: 8pt;
    border-left: 3pt solid #C8860A;
    page-break-after: avoid;
}

h3 {
    font-family: 'OsiaTitle', 'Ubuntu', sans-serif;
    font-size: 10pt;
    font-weight: bold;
    color: #ffd060;
    letter-spacing: 0.08em;
    margin: 10pt 0 4pt 0;
    page-break-after: avoid;
}

h4 {
    font-family: 'OsiaBody', 'Ubuntu Sans', sans-serif;
    font-size: 9.5pt;
    font-weight: bold;
    color: #c0b040;
    margin: 8pt 0 3pt 0;
    page-break-after: avoid;
}

p {
    margin: 0 0 7pt 0;
    text-align: justify;
    hyphens: auto;
}

strong, b {
    color: #E8DFC8;
    font-weight: bold;
}

em, i {
    color: #8A9688;
    font-style: italic;
}

a {
    color: #20c0e0;
    text-decoration: none;
}

/* ── Lists ─────────────────────────────────────────────────────── */
ul, ol {
    margin: 4pt 0 8pt 16pt;
    padding: 0;
}

li {
    margin-bottom: 3pt;
    text-align: left;
}

ul li::marker {
    color: #C8860A;
    content: "▸ ";
}

ol li::marker {
    color: #C8860A;
}

/* ── Code & Pre ────────────────────────────────────────────────── */
code {
    font-family: 'OsiaMono', 'Courier New', Courier, monospace;
    font-size: 8.5pt;
    background-color: #0a180a;
    color: #00dd55;
    padding: 1pt 3pt;
    border: 0.5pt solid #1a3a1a;
}

pre {
    background-color: #040c04;
    border: 1pt solid #1a3a1a;
    border-left: 3pt solid #00aa44;
    padding: 8pt 10pt;
    margin: 8pt 0;
    overflow-x: auto;
    font-size: 8pt;
    color: #00ee55;
    line-height: 1.4;
}

pre code {
    background: none;
    border: none;
    padding: 0;
    color: inherit;
}

/* ── Tables ────────────────────────────────────────────────────── */
table {
    width: 100%;
    border-collapse: collapse;
    margin: 8pt 0;
    font-size: 8.5pt;
}

th {
    background-color: #0c1c0c;
    color: #C8860A;
    font-family: 'OsiaMono', 'Courier New', Courier, monospace;
    font-weight: bold;
    padding: 5pt 8pt;
    text-align: left;
    border: 0.5pt solid #1e3a1e;
    letter-spacing: 0.06em;
    text-transform: uppercase;
}

td {
    padding: 4pt 8pt;
    border: 0.5pt solid #162016;
    vertical-align: top;
}

tr:nth-child(even) td {
    background-color: #0a120a;
}

tr:nth-child(odd) td {
    background-color: #0A0C0B;
}

/* ── Horizontal Rules ──────────────────────────────────────────── */
hr {
    border: none;
    border-top: 1pt dashed #1e3a1e;
    margin: 12pt 0;
}

/* ── Blockquotes (key assessments) ────────────────────────────── */
blockquote {
    border-left: 3pt solid #C8860A;
    background-color: #0c140a;
    margin: 8pt 0;
    padding: 6pt 12pt;
    color: #D4CFC4;
    font-style: italic;
}

/* ── Sources Section ───────────────────────────────────────────── */
h2#sources,
h2:has(+ ul > li > a),
.sources-section h2 {
    color: #40c0ff !important;
    border-left-color: #40c0ff !important;
}

/* ── Source Confidence indicators ──────────────────────────────── */
.source-confidence-high {
    color: #00dd55;
    font-weight: bold;
}

.source-confidence-moderate {
    color: #C8860A;
    font-weight: bold;
}

.source-confidence-low {
    color: #cc3333;
    font-weight: bold;
}

/* ── Section divider ───────────────────────────────────────────── */
.section-divider {
    text-align: center;
    color: #1e3a1e;
    font-family: 'OsiaMono', 'Courier New', Courier, monospace;
    font-size: 8pt;
    letter-spacing: 0.3em;
    margin: 10pt 0;
}

/* ── Page break helpers ─────────────────────────────────────────── */
.page-break {
    page-break-before: always;
}

.no-break {
    page-break-inside: avoid;
}
</style>
{% if bg_image_data_uri %}
<style>
/* Per-desk background: rendered beneath every page, dark overlay ensures legibility */
@page {
    background-image: url('{{ bg_image_data_uri }}');
    background-size: cover;
    background-position: center top;
}
body {
    background-image: linear-gradient(
        to bottom,
        rgba(10, 12, 11, 0.93) 0%,
        rgba(10, 12, 11, 0.91) 100%
    );
}
</style>
{% endif %}
<style>
  /* Per-desk accent colour injection */
  :root { --desk-accent: {{ desk_accent | default('#C8860A') }}; }
  .classification-banner:first-of-type { border-top: 4pt solid var(--desk-accent); }
  .doc-type, .ref-number { color: var(--desk-accent) !important; }
  h1 { color: var(--desk-accent) !important; border-bottom-color: color-mix(in srgb, var(--desk-accent) 35%, transparent) !important; }
  h2 { color: var(--desk-accent) !important; border-left-color: var(--desk-accent) !important; }
  ul li::marker, ol li::marker { color: var(--desk-accent); }
  .meta-item strong { color: var(--desk-accent) !important; }
  .doc-header { border-bottom-color: color-mix(in srgb, var(--desk-accent) 30%, transparent) !important; }
  .page-body { border-left-color: color-mix(in srgb, var(--desk-accent) 22%, transparent) !important; }
  blockquote { border-left-color: var(--desk-accent) !important; }
</style>
</head>
<body data-ref="{{ ref_number }}">

  <!-- Classification Banner (top) — accent bar via CSS :first-of-type -->
  <div class="classification-banner">
    ⬛&nbsp;&nbsp;OSIA INTERNAL USE ONLY — NOT FOR PUBLIC DISTRIBUTION&nbsp;&nbsp;⬛
  </div>

  <!-- Document Header -->
  <div class="doc-header">
    <div class="header-inner">
      <div class="logo-cell">
        {% if logo_data_uri %}
          <img src="{{ logo_data_uri }}" alt="OSIA Logo">
        {% else %}
          <div class="logo-placeholder">OSIA</div>
        {% endif %}
      </div>
      <div class="agency-identity">
        <div class="agency-name">Open Source Intelligence Agency</div>
        <div class="agency-subtitle">Automated Intelligence Collection &amp; Analysis Framework</div>
        <div class="doc-type">Intelligence Summary</div>
      </div>
      <div class="header-meta">
        <div class="ref-number">REF: {{ ref_number }}</div>
        <div class="header-timestamp">{{ timestamp }}</div>
        {% if desk_badge_uri %}
          <img src="{{ desk_badge_uri }}" alt="{{ desk_name }}" style="height:40pt;width:40pt;margin-top:6pt;opacity:0.85;">
        {% endif %}
      </div>
    </div>
  </div>

  <!-- Metadata Bar -->
  <div class="metadata-bar">
    <div class="meta-item"><strong>DESK:</strong> {{ desk_name }}</div>
    <div class="meta-item"><strong>SLUG:</strong> {{ desk_slug }}</div>
    <div class="meta-item meta-source"><strong>SOURCE:</strong> {{ source | truncate(55, true, '…') }}</div>
    <div class="meta-item"><strong>CLASS:</strong> INTERNAL USE ONLY</div>
  </div>

  <!-- Report Body -->
  <div class="page-body">
    <div class="section-divider">· · · · · · · · · · BEGIN TRANSMISSION · · · · · · · · · ·</div>

    {{ report_body | safe }}

    <div class="section-divider">· · · · · · · · · · END TRANSMISSION · · · · · · · · · · ·</div>
  </div>

  <!-- Classification Banner (bottom) -->
  <div class="classification-banner">
    ⬛&nbsp;&nbsp;OSIA INTERNAL USE ONLY — NOT FOR PUBLIC DISTRIBUTION&nbsp;&nbsp;⬛
  </div>

</body>
</html>
