<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>{{ desk_name }} — {{ week_label }}</title>
<style>
/* ================================================================
   OSIA WEEKLY BRIEFING — SLIDE TEMPLATE
   Aesthetic: Intelligence Agency Briefing Room
   Supports: landscape (16:9) and portrait (9:16)
   ================================================================ */

@page {
    size: {{ width }}px {{ height }}px;
    margin: 0;
}

* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

html, body {
    width: {{ width }}px;
    height: {{ height }}px;
    background-color: #0a0e0a;
    color: #c8dcc0;
    font-family: 'Helvetica Neue', 'Arial', sans-serif;
    overflow: hidden;
}

.slide {
    width: {{ width }}px;
    height: {{ height }}px;
    position: relative;
    display: flex;
    flex-direction: column;
    {% if orientation == 'landscape' %}
    padding: 48px 64px;
    {% else %}
    padding: 80px 48px 64px 48px;
    {% endif %}
    background: linear-gradient(160deg, #0a0e0a 0%, #0c140c 40%, #081008 100%);
}

/* ── AI-generated background image ─────────────────────────────── */
.slide-bg-image {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    z-index: 0;
}

/* Dark gradient overlay — ensures text legibility over the image */
.slide-bg-overlay {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: linear-gradient(
        160deg,
        rgba(10, 14, 10, 0.88) 0%,
        rgba(12, 20, 12, 0.82) 30%,
        rgba(8, 16, 8, 0.85) 70%,
        rgba(10, 14, 10, 0.92) 100%
    );
    z-index: 0;
}

/* ── Scanline texture ──────────────────────────────────────────── */
.slide::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background-image: repeating-linear-gradient(
        0deg,
        transparent,
        transparent 3px,
        rgba(0, 30, 0, 0.04) 3px,
        rgba(0, 30, 0, 0.04) 4px
    );
    pointer-events: none;
    z-index: 1;
}

/* ── Corner accents ────────────────────────────────────────────── */
.slide::after {
    content: '';
    position: absolute;
    top: 12px; left: 12px; right: 12px; bottom: 12px;
    border: 1px solid rgba(0, 180, 60, 0.12);
    pointer-events: none;
    z-index: 1;
}

/* ── Top bar ───────────────────────────────────────────────────── */
.top-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    {% if orientation == 'landscape' %}
    margin-bottom: 24px;
    {% else %}
    margin-bottom: 40px;
    {% endif %}
    position: relative;
    z-index: 2;
}

.top-bar-left {
    display: flex;
    align-items: center;
    gap: 16px;
}

.logo img {
    {% if orientation == 'landscape' %}
    height: 40px;
    {% else %}
    height: 48px;
    {% endif %}
    opacity: 0.85;
}

.logo-placeholder {
    {% if orientation == 'landscape' %}
    height: 40px;
    width: 40px;
    {% else %}
    height: 48px;
    width: 48px;
    {% endif %}
    border: 1.5px solid #1a4a1a;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 8px;
    color: #1a4a1a;
    letter-spacing: 0.1em;
}

.agency-label {
    font-size: 11px;
    color: #3a8a3a;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 600;
}

.top-bar-right {
    text-align: right;
}

.ref-label {
    font-size: 10px;
    color: #ff8c00;
    letter-spacing: 0.08em;
    font-family: 'Courier New', monospace;
}

.date-label {
    font-size: 9px;
    color: #3a6a3a;
    margin-top: 2px;
    font-family: 'Courier New', monospace;
}

/* ── Classification strip ──────────────────────────────────────── */
.classification-strip {
    background-color: rgba(100, 0, 0, 0.6);
    color: #ff4444;
    text-align: center;
    padding: 4px 0;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    font-family: 'Courier New', monospace;
    margin: 0 -64px;
    {% if orientation == 'portrait' %}
    margin: 0 -48px;
    {% endif %}
    position: relative;
    z-index: 2;
}

/* ── Desk badge ────────────────────────────────────────────────── */
.desk-badge {
    display: inline-block;
    background: rgba(255, 140, 0, 0.12);
    border: 1px solid rgba(255, 140, 0, 0.3);
    color: #ffa040;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 6px 16px;
    margin-top: 16px;
    position: relative;
    z-index: 2;
}

/* ── Content area ──────────────────────────────────────────────── */
.content {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    z-index: 2;
    overflow: hidden;
}

/* ── Title slide ───────────────────────────────────────────────── */
.slide-title-main {
    {% if orientation == 'landscape' %}
    font-size: 42px;
    {% else %}
    font-size: 38px;
    {% endif %}
    font-weight: 700;
    color: #00dd55;
    line-height: 1.2;
    margin-bottom: 16px;
    letter-spacing: -0.01em;
}

.slide-title-sub {
    {% if orientation == 'landscape' %}
    font-size: 20px;
    {% else %}
    font-size: 18px;
    {% endif %}
    color: #7ab87a;
    font-weight: 400;
    line-height: 1.4;
}

/* ── Content slide ─────────────────────────────────────────────── */
.slide-heading {
    {% if orientation == 'landscape' %}
    font-size: 28px;
    {% else %}
    font-size: 26px;
    {% endif %}
    font-weight: 700;
    color: #ff8c00;
    letter-spacing: 0.02em;
    margin-bottom: 20px;
    padding-bottom: 12px;
    border-bottom: 2px solid rgba(255, 140, 0, 0.25);
}

.slide-body {
    {% if orientation == 'landscape' %}
    font-size: 18px;
    line-height: 1.65;
    {% else %}
    font-size: 17px;
    line-height: 1.7;
    {% endif %}
    color: #b8d4b0;
}

.slide-body h1, .slide-body h2, .slide-body h3 {
    color: #ffa040;
    margin-top: 16px;
    margin-bottom: 8px;
}

.slide-body h1 { font-size: 24px; }
.slide-body h2 { font-size: 20px; }
.slide-body h3 { font-size: 18px; }

.slide-body p {
    margin-bottom: 12px;
}

.slide-body ul, .slide-body ol {
    margin: 8px 0 12px 24px;
}

.slide-body li {
    margin-bottom: 8px;
}

.slide-body ul li::marker {
    color: #ff8c00;
    content: "▸ ";
}

.slide-body strong, .slide-body b {
    color: #ddc090;
}

.slide-body em, .slide-body i {
    color: #90c890;
}

.slide-body code {
    font-family: 'Courier New', monospace;
    font-size: 0.85em;
    background: rgba(0, 180, 60, 0.08);
    color: #00dd55;
    padding: 2px 6px;
    border-radius: 3px;
}

/* ── Alert/warning callout ─────────────────────────────────────── */
.slide-body blockquote {
    border-left: 4px solid #ff4444;
    background: rgba(255, 0, 0, 0.06);
    padding: 12px 16px;
    margin: 12px 0;
    color: #e0b0b0;
    font-style: italic;
}

/* ── Footer ────────────────────────────────────────────────────── */
.slide-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 12px;
    border-top: 1px solid rgba(0, 180, 60, 0.15);
    position: relative;
    z-index: 2;
}

.footer-left {
    font-size: 10px;
    color: #2a5a2a;
    font-family: 'Courier New', monospace;
    letter-spacing: 0.05em;
}

.footer-right {
    font-size: 10px;
    color: #2a5a2a;
    font-family: 'Courier New', monospace;
}

.slide-counter {
    color: #ff8c00;
    font-weight: 600;
}

/* ── Title slide specific ──────────────────────────────────────── */
.title-slide .content {
    justify-content: center;
    align-items: center;
    text-align: center;
}

.title-content-centered {
    justify-content: center !important;
    align-items: center !important;
    text-align: center !important;
    gap: 24px;
    flex-direction: column !important;
}

.title-main-logo {
    {% if orientation == 'landscape' %}
    width: 320px;
    height: 320px;
    {% else %}
    width: 280px;
    height: 280px;
    {% endif %}
    object-fit: contain;
    filter: drop-shadow(0 0 40px rgba(0, 200, 80, 0.3));
    margin-bottom: 8px;
}

.title-agency-name {
    {% if orientation == 'landscape' %}
    font-size: 36px;
    {% else %}
    font-size: 30px;
    {% endif %}
    font-weight: 700;
    color: #00dd55;
    letter-spacing: 0.08em;
    text-transform: uppercase;
}

.title-tagline {
    font-size: 16px;
    color: #5a9a5a;
    letter-spacing: 0.12em;
    font-style: italic;
    margin-top: 8px;
}

/* ── Closing slide ─────────────────────────────────────────────── */
.closing-slide .content {
    justify-content: center;
    align-items: center;
    text-align: center;
}

.closing-slide .slide-title-main {
    font-size: 32px;
    color: #3a8a3a;
}

/* ── Desk intro: portrait + content side-by-side ───────────────── */
.content-with-portrait {
    flex-direction: row !important;
    align-items: center;
    gap: 40px;
}

.portrait-panel {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
}

.dept-portrait {
    {% if orientation == 'landscape' %}
    width: 260px;
    height: 260px;
    {% else %}
    width: 200px;
    height: 200px;
    {% endif %}
    border-radius: 8px;
    border: 2px solid color-mix(in srgb, var(--desk-accent) 40%, transparent);
    box-shadow: 0 0 32px rgba(0,0,0,0.6), 0 0 16px color-mix(in srgb, var(--desk-accent) 15%, transparent);
    object-fit: cover;
}

.dept-portrait-name {
    font-size: 12px;
    color: var(--desk-accent);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-family: 'Courier New', monospace;
    text-align: center;
}

.portrait-content {
    flex: 1;
    min-width: 0;
}
</style>
<style>
  /* Per-desk accent colour */
  :root { --desk-accent: {{ desk_accent | default('#C8860A') }}; }
  .slide-heading { color: var(--desk-accent) !important; border-bottom-color: color-mix(in srgb, var(--desk-accent) 25%, transparent) !important; }
  .desk-badge { color: var(--desk-accent) !important; border-color: color-mix(in srgb, var(--desk-accent) 30%, transparent) !important; background: color-mix(in srgb, var(--desk-accent) 12%, transparent) !important; }
  .ref-label { color: var(--desk-accent) !important; }
  .slide-body ul li::marker { color: var(--desk-accent); }
  .title-slide .presenter-portrait { border-color: color-mix(in srgb, var(--desk-accent) 40%, transparent) !important; }
</style>
</head>
<body>

<div class="slide {% if slide_type == 'title' %}title-slide{% elif slide_type == 'closing' %}closing-slide{% endif %}">

  {% if bg_image_data_uri %}
  <div class="slide-bg-image" style="background-image: url('{{ bg_image_data_uri }}');"></div>
  <div class="slide-bg-overlay"></div>
  {% endif %}

  <!-- Top bar -->
  <div class="top-bar">
    <div class="top-bar-left">
      <div class="logo">
        {% if logo_data_uri %}
          <img src="{{ logo_data_uri }}" alt="OSIA">
        {% else %}
          <div class="logo-placeholder">OSIA</div>
        {% endif %}
      </div>
      <span class="agency-label">Open Source Intelligence Agency</span>
    </div>
    <div class="top-bar-right">
      <div class="ref-label">{{ ref_number }}</div>
      <div class="date-label">{{ timestamp }}</div>
    </div>
  </div>

  <!-- Classification -->
  <div class="classification-strip">
    ⬛ OSIA INTERNAL USE ONLY ⬛
  </div>

  {% if slide_type == 'title' %}
  <!-- ═══ TITLE SLIDE ═══ -->
  <div class="content title-content-centered">
    {% if logo_data_uri %}
    <img class="title-main-logo" src="{{ logo_data_uri }}" alt="OSIA">
    {% endif %}
    <div class="title-agency-name">Open Source Intelligence Agency</div>
    <div class="title-tagline">Intelligence for the people, the land, and the future.</div>
  </div>

  {% elif slide_type == 'closing' %}
  <!-- ═══ CLOSING SLIDE ═══ -->
  <div class="content">
    <div class="slide-title-main">{{ slide_title }}</div>
    <div class="slide-body">{{ slide_body | safe }}</div>
  </div>

  {% else %}
  <!-- ═══ CONTENT SLIDE ═══ -->
  <div class="desk-badge">{{ desk_name }}</div>
  {% if portrait_data_uri %}
  <!-- Portrait + content side-by-side layout for desk intro slides -->
  <div class="content content-with-portrait">
    <div class="portrait-panel">
      <img class="dept-portrait" src="{{ portrait_data_uri }}" alt="{{ persona_name }}">
      <div class="dept-portrait-name">{{ persona_name }}</div>
    </div>
    <div class="portrait-content">
      <div class="slide-heading">{{ slide_title }}</div>
      <div class="slide-body">{{ slide_body | safe }}</div>
    </div>
  </div>
  {% else %}
  <div class="content">
    <div class="slide-heading">{{ slide_title }}</div>
    <div class="slide-body">{{ slide_body | safe }}</div>
  </div>
  {% endif %}
  {% endif %}

  <!-- Footer -->
  <div class="slide-footer">
    <div class="footer-left">{{ desk_slug }} · {{ week_label }}</div>
    <div class="footer-right">
      <span class="slide-counter">{{ slide_number }}</span> / {{ total_slides }}
    </div>
  </div>

</div>

</body>
</html>
