# === Required ===
GEMINI_API_KEY=your_gemini_api_key_here
SIGNAL_SENDER_NUMBER=+1234567890        # The Signal number registered with signal-cli
ANYTHINGLLM_API_KEY=your_anythingllm_api_key_here
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_URL=https://qdrant.osia.dev          # Qdrant HTTP endpoint

# === Analytical Mandate (optional) ===
OSIA_DIRECTIVES_FILE=DIRECTIVES.md          # Path to analytical mandate file (defaults to DIRECTIVES.md; set to empty string to disable)

# === Optional (defaults shown) ===
REDIS_URL=redis://localhost:6379/0
SIGNAL_API_URL=http://localhost:8081    # Used by orchestrator for sending messages
SIGNAL_WS_URL=ws://localhost:8081       # Base URL for WebSocket listener (number appended automatically)
ANYTHINGLLM_BASE_URL=http://localhost:3001
GEMINI_MODEL_ID=gemini-2.5-flash
GEMINI_IMAGE_MODEL_ID=gemini-2.5-flash-image  # Image generation model for infographics
OSIA_TASK_QUEUE=osia:task_queue
SIGNAL_GROUP_ID= # THe Signal group

# === External APIs ===
GEMINI_API_KEY=  ## Google Gemini API Key
OPENAI_API_KEY= ## OpenAI API Key
TAVILY_API_KEY= ## Tavily API key
ANTHROPIC_API_KEY= ## Antrhopic API key
OPENROUTER_API_KEY= ## OpenRouter API key — kept for non-Venice model access (https://openrouter.ai)
VENICE_API_KEY=     ## Venice API key — primary research worker backend, uncensored models (https://venice.ai)

# === Research Worker (local service) ===
RESEARCH_BATCH_THRESHOLD=3               # Min queue depth before running a research batch
RESEARCH_WORKER_MODEL_DOLPHIN=cognitivecomputations/dolphin3.0-r1-mistral-24b  # Uncensored model for HUMINT/Cultural/Geo desks
RESEARCH_WORKER_MODEL_DEFAULT=mistralai/mistral-small-3.1-24b-instruct          # Model for Cyber/Finance/Science desks

# === HuggingFace (embeddings + optional jobs) ===
HF_TOKEN=hf_your_write_token_here           # HuggingFace token (still used for embeddings via router.huggingface.co)
HF_NAMESPACE=your_hf_username               # HuggingFace username or org name

# === Paths (override if not running from /home/ubuntu) ===
OSIA_BASE_DIR=/home/ubuntu/osia-framework   # Root of this project
MCP_TOOLS_BASE=/home/ubuntu                  # Parent dir containing mcp-arxiv, mcp-wikipedia-py, etc.

# === Phone Bridge Auth ===
PHONE_BRIDGE_TOKEN=                          # Set a secret token to protect the ADB bridge endpoint

# === Status API ===
STATUS_API_TOKEN=                            # Bearer token for the status API (generate with: uv run python scripts/manage_status_token.py --rotate)
STATUS_API_UA_SENTINEL=osia-monitor/1        # Cryptic User-Agent string required on every request
STATUS_API_PORT=8099                         # Port the status API listens on

# === Queue API (Redis HTTP wrapper for remote workers) ===
QUEUE_API_TOKEN=                             # Bearer token for the queue API (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
QUEUE_API_UA_SENTINEL=osia-worker/1          # User-Agent sentinel required on every request
QUEUE_API_PORT=8098                          # Port the queue API listens on

# === Ingress API (intelligence task submission — https://ingress.osia.dev) ===
INGRESS_API_TOKEN=                           # Bearer token (generate with: uv run python scripts/manage_ingress_token.py --rotate)
INGRESS_API_UA_SENTINEL=osia-ingress/1       # User-Agent sentinel required on every request
INGRESS_API_PORT=8097                        # Port the ingress API listens on

SIGNAL_GROUP_ID=                             # Signal group ID for daily briefing delivery (e.g. group.base64encodedid)

# === Persona Daemon ===
# Each persona uses PERSONA_<id>_* env vars. Run multiple instances with --persona <id>.
# Fallback timezone applies to all personas unless overridden per-persona.
PERSONA_TZ_OFFSET=10                         # Default UTC offset (10 = AEST)

# --- Persona 1 ---
PERSONA_1_NAME=David Thorne
PERSONA_1_BIO=                               # Optional inline bio (or use config/persona_1_bio.txt)
PERSONA_1_TZ_OFFSET=                         # Override timezone for this persona (defaults to PERSONA_TZ_OFFSET)
PERSONA_1_LIKE_CAP=80                        # Max likes per day
PERSONA_1_COMMENT_CAP=30                     # Max comments per day
PERSONA_1_POST_CAP=3                         # Max original posts per day
PERSONA_1_MIN_GAP=8                          # Min minutes between sessions
PERSONA_1_MAX_GAP=35                         # Max minutes between sessions
PERSONA_1_QUIET_START=23                     # Hour (local) quiet period starts
PERSONA_1_QUIET_END=8                        # Hour (local) quiet period ends

# --- Persona 2 (example — uncomment and add a second systemd service) ---
# PERSONA_2_NAME=Jane Smith
# PERSONA_2_BIO=a 28-year-old graphic designer from Melbourne who loves street art and indie music
# PERSONA_2_LIKE_CAP=40
# PERSONA_2_COMMENT_CAP=10
# PERSONA_2_POST_CAP=2

# === ADB Device Routing ===
ADB_DEVICE_PERSONA_1=                        # Device ID for Persona 1 (leave blank for any connected device)
ADB_DEVICE_PERSONA_2=                        # Device ID for Persona 2
ADB_DEVICE_MEDIA_INTERCEPT=                  # Device ID for general media scraping
ADB_DEVICE_DEFAULT=                          # Device ID for the Phone Bridge

# === X/Twitter Ingress (via TwitterAPI.io) ===
TWITTERAPI_IO_KEY=                           # API key from https://twitterapi.io/dashboard
X_POLL_INTERVAL=900                          # Seconds between poll cycles (default: 900 = 15 min)

# === Github ===
GITHUB_TOKEN=

# === Eleven Labs ===
ELEVENLABS_API_KEY=
